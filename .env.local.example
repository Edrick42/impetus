# Site (em produção: https://institutoimpetus.com.br)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------
# Galeria — Supabase (auth + banco)
# ---------------------------------------------------------------
# Criar projeto em https://supabase.com, copiar a URL e a anon key.
# A service role key NUNCA vai pro client — só usar em rotas server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------
# Galeria — Cloudflare R2 (storage de imagens)
# ---------------------------------------------------------------
# Em Cloudflare Dashboard > R2: criar bucket "impetus-gallery", expor
# em domínio público (custom domain de preferência) e gerar API token
# com permissão de leitura+escrita no bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=impetus-gallery
# URL pública de servir as fotos. Ex: https://fotos.institutoimpetus.com.br
# (custom domain do bucket) ou https://pub-<hash>.r2.dev (subdomínio CF).
R2_PUBLIC_URL=

# ---------------------------------------------------------------
# Piwigo — LEGADO, mantém como fallback até a galeria nova entrar em produção
# ---------------------------------------------------------------
PIWIGO_API_URL=
PIWIGO_USERNAME=
PIWIGO_PASSWORD=

# Instagram Graph API (opcional — ativa o feed)
IG_ACCESS_TOKEN=
IG_USER_ID=

# Microsoft Clarity (heatmap + session replay — produção)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
